// ─── Helpers ──────────────────────────────────────────────────────────────────
function parseDate(str) {
  if (!str) return null;
  const d = new Date(str);
  return isNaN(d.getTime()) ? null : d;
}

function daysDiff(dateStr) {
  // Positive = future, negative = past
  const d = parseDate(dateStr);
  if (!d) return null;
  const ms = d - TODAY;
  return Math.round(ms / 86400000);
}

function fmtDate(dateStr) {
  const d = parseDate(dateStr);
  if (!d) return '';
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

function urgencyColor(days) {
  if (days === null)  return '#64748b';
  if (days < 0)       return '#dc2626';  // overdue
  if (days <= 5)      return '#d97706';
  if (days <= 14)     return '#6366f1';
  return '#64748b';
}

function daysLabel(days) {
  if (days === null) return '';
  if (days === 0)    return 'today';
  if (days < 0)      return `${Math.abs(days)}d overdue`;
  return `${days}d`;
}

function timelinePct(lastDate, nextDate) {
  const l = parseDate(lastDate);
  const n = parseDate(nextDate);
  if (!l || !n) return null;
  const total   = n - l;
  const elapsed = TODAY - l;
  if (total <= 0) return null;
  return Math.min(Math.max((elapsed / total) * 100, 2), 96);
}

function esc(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

// ─── Schedule date parsing ────────────────────────────────────────────────────
// Milestone dates come in three formats: "Sep 2025", "May 2026" (Mon YYYY),
// or "Dec 8", "Mar 4" (Mon D — no year). For the year-less format, default to
// 2026, but if that lands more than 6 months past TODAY it's almost certainly
// a 2025 date (e.g. "Dec 8" for a completed EVT milestone).
function parseScheduleDate(str) {
  if (!str) return null;
  str = str.trim();

  // "Sep 2025" / "May 2026" — explicit year
  const monYear = str.match(/^([A-Za-z]+)\s+(\d{4})$/);
  if (monYear) {
    const d = new Date(`${monYear[1]} 1, ${monYear[2]}`);
    return isNaN(d) ? null : d;
  }

  // "Dec 8" / "Mar 4" — infer year
  const monDay = str.match(/^([A-Za-z]+)\s+(\d{1,2})$/);
  if (monDay) {
    const d2026 = new Date(`${monDay[1]} ${monDay[2]}, 2026`);
    if (!isNaN(d2026)) {
      const cutoff = new Date(TODAY);
      cutoff.setMonth(cutoff.getMonth() + 6);
      if (d2026 > cutoff) {
        const d2025 = new Date(`${monDay[1]} ${monDay[2]}, 2025`);
        return isNaN(d2025) ? d2026 : d2025;
      }
      return d2026;
    }
  }

  return null;
}

// Given a milestone array, return the fractional position (0–1) of TODAY
// within the equally-spaced flex columns, interpolated by actual date.
// Column center for index i = (i + 0.5) / n
function todayPositionInSchedule(milestones) {
  const n = milestones.length;
  if (n === 0) return null;

  const dates = milestones.map(m => parseScheduleDate(m.date));
  const colCenter = i => (i + 0.5) / n;

  // Last milestone whose date is on or before TODAY
  let prevIdx = -1;
  for (let i = 0; i < n; i++) {
    if (dates[i] && dates[i] <= TODAY) prevIdx = i;
  }
  // First milestone whose date is after TODAY
  let nextIdx = -1;
  for (let i = 0; i < n; i++) {
    if (dates[i] && dates[i] > TODAY) { nextIdx = i; break; }
  }

  if (prevIdx === -1 && nextIdx === -1) return null; // no parseable dates

  // TODAY is before all milestones
  if (prevIdx === -1) return colCenter(nextIdx) / 2;

  // TODAY is after all milestones
  if (nextIdx === -1) return (colCenter(prevIdx) + 1) / 2;

  // Interpolate between the two bracketing milestone column centers
  const span = dates[nextIdx] - dates[prevIdx];
  if (span <= 0) return colCenter(prevIdx);
  const frac = (TODAY - dates[prevIdx]) / span;
  return colCenter(prevIdx) + frac * (colCenter(nextIdx) - colCenter(prevIdx));
}

// ─── Build top nav status summary ────────────────────────────────────────────
function buildNavStatus() {
  const counts = { 'at-risk': 0, 'watch': 0, 'on-track': 0 };
  PROGRAMS.forEach(p => { if (counts[p.status] !== undefined) counts[p.status]++; });

  const parts = [];
  if (counts['at-risk'] > 0)  parts.push(`<span class="status-pill" style="color:${RAG['at-risk'].navDot}"><span>&#9679;</span><span style="color:#94a3b8">${counts['at-risk']} ${RAG['at-risk'].label}</span></span>`);
  if (counts['watch'] > 0)    parts.push(`<span class="status-pill" style="color:${RAG['watch'].navDot}"><span>&#9679;</span><span style="color:#94a3b8">${counts['watch']} ${RAG['watch'].label}</span></span>`);
  if (counts['on-track'] > 0) parts.push(`<span class="status-pill" style="color:${RAG['on-track'].navDot}"><span>&#9679;</span><span style="color:#94a3b8">${counts['on-track']} ${RAG['on-track'].label}</span></span>`);

  document.getElementById('status-summary').innerHTML = parts.join('<span style="color:#334155;font-size:10px">·</span>');

  const dateStr = TODAY.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
  document.getElementById('nav-date').textContent = dateStr;
}

// ─── Build milestone ticker ───────────────────────────────────────────────────
function buildTicker() {
  const ticker = document.getElementById('ticker');
  const pills = [];

  PROGRAMS.forEach(prog => {
    if (!prog.nextGate || !prog.nextGate.date) return;
    const days = daysDiff(prog.nextGate.date);
    if (days === null || days < 0 || days > 30) return;
    pills.push({ prog, days, gate: prog.nextGate.label, date: prog.nextGate.date });
  });

  // Sort ascending by date
  pills.sort((a, b) => a.days - b.days);

  if (pills.length === 0) {
    ticker.insertAdjacentHTML('beforeend', '<span id="ticker-empty">No milestones in window</span>');
    return;
  }

  const rag = RAG;
  pills.forEach(({ prog, days, gate }) => {
    const r = rag[prog.status];
    const statusColor = r.border;
    const borderColor = statusColor + '33'; // 20% opacity hex approx
    const daysColor = days <= 7 ? '#fbbf24' : '#6366f1';
    const daysText = days === 0 ? 'today' : `+${days}d`;

    const pill = document.createElement('span');
    pill.className = 'ticker-pill';
    pill.style.border = `1px solid ${borderColor}`;
    pill.innerHTML = `<span class="ticker-pill-prog" style="color:${statusColor}">${esc(prog.name)}</span><span class="ticker-pill-gate">${esc(gate)}</span><span class="ticker-pill-days" style="color:${daysColor}">${daysText}</span>`;
    ticker.appendChild(pill);
  });
}

// ─── Build cards ─────────────────────────────────────────────────────────────
function buildCards() {
  const grid = document.getElementById('card-grid');

  PROGRAMS.forEach(prog => {
    const r = RAG[prog.status] || RAG['watch'];
    const ph = PHASE_BADGE[prog.phase] || PHASE_BADGE['In Design'];

    // ── Header
    const headerHTML = `
      <div class="card-header">
        <div class="card-header-left">
          <span class="card-name">${esc(prog.name)}</span>
          ${prog.subtitle ? `<span class="card-subtitle">${esc(prog.subtitle)}</span>` : ''}
        </div>
        <div class="card-header-right">
          <span class="badge-phase" style="background:${ph.bg};color:${ph.text}">${esc(prog.phase)}</span>
          <span class="badge-rag" style="background:${r.labelBg};color:${r.labelText}">${r.label}</span>
        </div>
      </div>`;

    // ── Timeline strip
    let timelineHTML;
    const hasLast = prog.lastGate && prog.lastGate.date;
    const hasNext = prog.nextGate && prog.nextGate.date;

    if (hasLast && hasNext) {
      const pct = timelinePct(prog.lastGate.date, prog.nextGate.date);
      const todayPct = pct !== null ? pct : 50;
      // Gate marker at right end (96% to avoid overflow)
      const gateLeft = Math.min(Math.max(todayPct + 8, 90), 96);

      const nextDays = daysDiff(prog.nextGate.date);
      const nextColor = urgencyColor(nextDays);

      timelineHTML = `
        <div class="timeline-wrap">
          <div class="timeline-bar-outer">
            <div class="timeline-bar-fill" style="width:${todayPct}%;background:${r.trackFill}"></div>
            <div class="timeline-today" style="left:${todayPct}%"></div>
            <div class="timeline-gate" style="left:${gateLeft}%;background:${r.border}"></div>
          </div>
          <div class="timeline-labels">
            <span>${esc(prog.lastGate.label)} · ${fmtDate(prog.lastGate.date)}</span>
            <span class="timeline-right-label" style="color:${nextColor}">${esc(prog.nextGate.label)} · ${fmtDate(prog.nextGate.date)}</span>
          </div>
        </div>`;
    } else {
      timelineHTML = `
        <div class="timeline-wrap">
          <div class="timeline-dashed"></div>
          <span class="timeline-pending">Timeline pending</span>
        </div>`;
    }

    // ── Next gate section
    let nextGateHTML;
    if (prog.nextGate && prog.nextGate.label) {
      const days = daysDiff(prog.nextGate.date);
      const color = urgencyColor(days);
      const chipsHTML = (prog.nextGate.criteria || [])
        .map(c => `<span class="criteria-chip">${esc(c)}</span>`)
        .join('');

      nextGateHTML = `
        <div>
          <div class="next-gate-label">Next Gate</div>
          <div class="next-gate-row">
            <span class="next-gate-name">${esc(prog.nextGate.label)}</span>
            ${prog.nextGate.date ? `<span class="next-gate-date" style="color:${color}">${fmtDate(prog.nextGate.date)}</span>` : ''}
            ${days !== null ? `<span class="next-gate-days" style="color:${color}">${daysLabel(days)}</span>` : ''}
          </div>
          ${chipsHTML ? `<div class="criteria-wrap">${chipsHTML}</div>` : ''}
        </div>`;
    } else {
      nextGateHTML = `<div><span class="next-gate-empty">Awaiting update</span></div>`;
    }

    // ── Risks (max 2)
    const visibleRisks = (prog.risks || []).slice(0, 2);
    let risksHTML = '';
    if (visibleRisks.length > 0) {
      const rows = visibleRisks.map(risk => `
        <div class="risk-row">
          <span class="risk-icon">⚠</span>
          <span class="item-label">${esc(risk.label)}</span>
          <span class="item-meta">${esc(risk.owner)}</span>
        </div>`).join('');
      risksHTML = `<div class="risks-section"><div class="section-label">Risks</div>${rows}</div>`;
    }

    // ── Decisions (max 2)
    const visibleDecisions = (prog.decisions || []).slice(0, 2);
    let decisionsHTML = '';
    if (visibleDecisions.length > 0) {
      const rows = visibleDecisions.map(d => `
        <div class="decision-row">
          <span class="decision-icon">◆</span>
          <span class="item-label">${esc(d.label)}</span>
          <span class="item-meta">${esc(d.owner)}${d.date ? ' · ' + esc(d.date) : ''}</span>
        </div>`).join('');
      decisionsHTML = `<div class="decisions-section"><div class="section-label">Decisions</div>${rows}</div>`;
    }

    // ── Divider + combined bottom section
    const hasRisksOrDecisions = visibleRisks.length > 0 || visibleDecisions.length > 0;
    const dividerHTML = hasRisksOrDecisions ? '<hr class="card-divider" />' : '';
    const bottomHTML = hasRisksOrDecisions
      ? `${dividerHTML}${risksHTML}${decisionsHTML}`
      : '';

    // ── Assemble card
    const card = document.createElement('div');
    card.className = 'card';
    card.style.borderLeftColor = r.border;
    card.dataset.progId = prog.id;
    card.innerHTML = headerHTML + timelineHTML + nextGateHTML + bottomHTML;
    card.addEventListener('click', () => openModal(prog.id));
    grid.appendChild(card);
  });
}

// ─── Modal ───────────────────────────────────────────────────────────────────
function buildScheduleTrack(milestones, trackLabel, statusColor) {
  if (!milestones || milestones.length === 0) return '';

  const dots = milestones.map(m => {
    const isCurrent  = m.status === 'current';
    const isComplete = m.status === 'complete';

    const dotStyle = isCurrent
      ? `background:${statusColor};color:${statusColor};border:2px solid white;box-shadow:0 0 0 2px ${statusColor};`
      : isComplete
        ? `background:#94a3b8;`
        : `background:white;border:1.5px solid #cbd5e1;`;

    const nameClass = isCurrent ? 'sched-name current' : 'sched-name';

    return `
      <div class="schedule-milestone">
        <span class="${nameClass}">${esc(m.label)}</span>
        <div class="sched-dot ${m.status}" style="${dotStyle}"></div>
        <span class="sched-date">${esc(m.date)}</span>
      </div>`;
  }).join('');

  return `
    <div class="schedule-track">
      <div class="schedule-track-row">
        <span class="schedule-track-label">${esc(trackLabel)}</span>
        <div class="schedule-milestones">${dots}</div>
      </div>
    </div>`;
}

function openModal(progId) {
  const prog = PROGRAMS.find(p => p.id === progId);
  if (!prog) return;

  const r  = RAG[prog.status] || RAG['watch'];
  const ph = PHASE_BADGE[prog.phase] || PHASE_BADGE['In Design'];

  // ── Modal header
  const headerHTML = `
    <div class="modal-header">
      <div class="modal-header-left">
        <span class="modal-title" id="modal-title-text">${esc(prog.name)}</span>
        ${prog.subtitle ? `<span class="modal-subtitle">${esc(prog.subtitle)}</span>` : ''}
      </div>
      <div class="modal-header-right">
        <span class="badge-phase" style="background:${ph.bg};color:${ph.text}">${esc(prog.phase)}</span>
        <span class="badge-rag" style="background:${r.labelBg};color:${r.labelText}">${r.label}</span>
        <button id="modal-close" aria-label="Close modal">&#10005;</button>
      </div>
    </div>`;

  // ── Program Schedule section
  let scheduleHTML = '';
  if (prog.programSchedule) {
    const hwTrack = buildScheduleTrack(prog.programSchedule.hw, 'HW', r.border);
    const swTrack = buildScheduleTrack(prog.programSchedule.sw, 'SW', r.border);
    if (hwTrack || swTrack) {
      // TODAY marker: single spanning line across both HW and SW rows.
      // Position is date-interpolated: TODAY falls proportionally between the two
      // milestone column centers that bracket it, based on actual parsed dates.
      // .schedule-track-label is width:20px + gap:8px = 28px before the milestones area,
      // so the CSS calc accounts for that offset.
      let todaySpanHTML = '';
      const hwMs = prog.programSchedule.hw || [];
      const todayFrac = todayPositionInSchedule(hwMs);
      if (todayFrac !== null) {
        todaySpanHTML = `<div class="sched-today-marker" style="left:calc(28px + (100% - 28px) * ${todayFrac.toFixed(4)})"></div>`;
      }

      scheduleHTML = `
        <div>
          <div class="modal-section-label">Program Schedule</div>
          <div style="position:relative">
            ${hwTrack}
            ${swTrack}
            ${todaySpanHTML}
          </div>
        </div>`;
    }
  }

  // ── Next Gate section (full criteria)
  let nextGateHTML = '';
  if (prog.nextGate && prog.nextGate.label) {
    const days  = daysDiff(prog.nextGate.date);
    const color = urgencyColor(days);
    const chipsHTML = (prog.nextGate.criteria || [])
      .map(c => `<span class="criteria-chip">${esc(c)}</span>`)
      .join('');

    nextGateHTML = `
      <div>
        <div class="modal-section-label">Next Gate</div>
        <div class="next-gate-row">
          <span class="next-gate-name">${esc(prog.nextGate.label)}</span>
          ${prog.nextGate.date ? `<span class="next-gate-date" style="color:${color}">${fmtDate(prog.nextGate.date)}</span>` : ''}
          ${days !== null ? `<span class="next-gate-days" style="color:${color}">${daysLabel(days)}</span>` : ''}
        </div>
        ${chipsHTML ? `<div class="modal-criteria-wrap">${chipsHTML}</div>` : ''}
      </div>`;
  }

  // ── Decisions section
  const modalDecisions = prog.modalDecisions || [];
  let decisionsHTML = '';
  if (modalDecisions.length > 0) {
    const blocks = modalDecisions.map(d => {
      const optionsHTML = (d.options || [])
        .map(o => `<div class="modal-decision-option">${esc(o)}</div>`)
        .join('');
      return `
        <div class="modal-decision-block">
          <div class="modal-decision-row">
            <div class="modal-decision-left">
              <span style="color:#6366f1;flex-shrink:0">◆</span>
              <span class="modal-decision-label">${esc(d.label)}</span>
            </div>
            <span class="modal-decision-meta">${esc(d.owner)}${d.date ? ' · ' + esc(d.date) : ''}</span>
          </div>
          ${optionsHTML ? `<div class="modal-decision-options">${optionsHTML}</div>` : ''}
        </div>`;
    }).join('');

    decisionsHTML = `
      <div>
        <div class="modal-section-label">Open Decisions</div>
        ${blocks}
      </div>`;
  }

  // ── Risks section
  const modalRisks = prog.modalRisks || [];
  let risksHTML = '';
  if (modalRisks.length > 0) {
    const RAG_LABELS = { red: 'RED', amber: 'AMBER', green: 'GREEN' };
    const blocks = modalRisks.map(risk => {
      const dot = risk.rag
        ? `<span class="risk-rag risk-rag-${risk.rag}" title="${RAG_LABELS[risk.rag] || risk.rag}"></span>`
        : `<span style="color:#f59e0b;flex-shrink:0;font-size:11px">⚠</span>`;
      return `
      <div class="modal-risk-block">
        <div class="modal-risk-row">
          <div class="modal-risk-left">
            ${dot}
            <span class="modal-risk-label">${esc(risk.label)}</span>
          </div>
          ${risk.owner ? `<span class="modal-risk-meta">${esc(risk.owner)}</span>` : ''}
        </div>
        ${risk.description ? `<div class="modal-risk-desc">${esc(risk.description)}</div>` : ''}
      </div>`;
    }).join('');

    risksHTML = `
      <div>
        <div class="modal-section-label">Risks</div>
        ${blocks}
      </div>`;
  }

  // ── Assemble modal content with dividers
  const sections = [];
  sections.push(headerHTML);
  if (scheduleHTML) {
    sections.push('<hr class="modal-divider" />');
    sections.push(scheduleHTML);
  }
  if (nextGateHTML) {
    sections.push('<hr class="modal-divider" />');
    sections.push(nextGateHTML);
  }
  if (decisionsHTML) {
    sections.push('<hr class="modal-divider" />');
    sections.push(decisionsHTML);
  }
  if (risksHTML) {
    sections.push('<hr class="modal-divider" />');
    sections.push(risksHTML);
  }

  const modalContent = document.getElementById('modal-content');
  modalContent.innerHTML = sections.join('');

  // Set left border color to match program RAG
  document.getElementById('modal').style.borderLeftColor = r.border;

  // Wire close button
  document.getElementById('modal-close').addEventListener('click', closeModal);

  // Open
  document.getElementById('modal-backdrop').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('modal-backdrop').classList.remove('open');
  document.body.style.overflow = '';
}

// Close on backdrop click (outside modal)
document.getElementById('modal-backdrop').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// Close on Escape key
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeModal();
});

// ─── Initialize ───────────────────────────────────────────────────────────────
buildNavStatus();
buildTicker();
buildCards();
</script>
