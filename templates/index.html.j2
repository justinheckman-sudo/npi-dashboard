<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NPI Portfolio Dashboard</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f1f5f9;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── Top Nav Bar ─────────────────────────────────── */
    #nav {
      background: #0f172a;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 24px;
      flex-shrink: 0;
    }
    #nav-left { display: flex; align-items: baseline; gap: 8px; }
    #nav-brand { color: white; font-weight: 800; font-size: 15px; }
    #nav-sub   { color: #475569; font-size: 12px; }
    #nav-right { display: flex; align-items: center; gap: 12px; }
    #status-summary { display: flex; flex-direction: row; flex-wrap: nowrap; align-items: center; gap: 8px; }
    .status-pill { font-size: 11px; font-weight: 600; display: flex; align-items: center; gap: 4px; white-space: nowrap; }
    .status-sep  { width: 1px; height: 16px; background: #1e293b; margin: 0 4px; }
    #nav-date    { color: #334155; font-size: 11px; }

    /* ── Milestone Ticker Bar ────────────────────────── */
    #ticker {
      background: #1e293b;
      height: 32px;
      display: flex;
      align-items: center;
      padding: 0 24px;
      gap: 6px;
      overflow-x: auto;
      flex-shrink: 0;
      scrollbar-width: none;
    }
    #ticker::-webkit-scrollbar { display: none; }
    #ticker-label {
      color: #475569;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.08em;
      white-space: nowrap;
      margin-right: 6px;
    }
    .ticker-pill {
      background: #0f172a;
      border-radius: 20px;
      padding: 3px 10px;
      font-size: 11px;
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .ticker-pill-prog  { font-weight: 700; }
    .ticker-pill-gate  { color: #94a3b8; }
    .ticker-pill-days  { font-weight: 700; }
    #ticker-empty { color: #475569; font-size: 11px; }

    /* ── Card Grid ───────────────────────────────────── */
    #grid-wrap {
      flex: 1;
      padding: 14px;
    }
    #card-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }
    @media (max-width: 1099px) {
      #card-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 699px) {
      #card-grid { grid-template-columns: 1fr; }
      #grid-wrap { padding: 10px; }
    }

    /* ── Program Card ────────────────────────────────── */
    .card {
      background: white;
      border-radius: 10px;
      border-top: 1px solid #e2e8f0;
      border-right: 1px solid #e2e8f0;
      border-bottom: 1px solid #e2e8f0;
      border-left-width: 4px;
      border-left-style: solid;
      /* border-left-color set by JS to RAG status color */
      box-shadow: 0 1px 4px rgba(0,0,0,0.05);
      padding: 14px 16px 12px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      cursor: pointer;
      transition: box-shadow 0.15s ease, transform 0.1s ease;
    }
    .card:hover {
      box-shadow: 0 4px 16px rgba(0,0,0,0.1);
      transform: translateY(-1px);
    }
    @media (max-width: 699px) {
      .card { padding: 10px 12px; }
    }

    /* Card header */
    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .card-header-left { display: flex; align-items: baseline; gap: 7px; }
    .card-name     { font-weight: 800; font-size: 15px; color: #0f172a; }
    .card-subtitle { font-size: 11px; color: #94a3b8; }
    .card-header-right { display: flex; align-items: center; gap: 5px; }
    .badge-phase {
      font-size: 10px;
      font-weight: 600;
      padding: 2px 7px;
      border-radius: 4px;
    }
    .badge-rag {
      font-size: 10px;
      font-weight: 700;
      padding: 2px 7px;
      border-radius: 4px;
    }

    /* Timeline strip */
    .timeline-wrap { display: flex; flex-direction: column; gap: 4px; }
    .timeline-bar-outer {
      position: relative;
      height: 5px;
      background: #e2e8f0;
      border-radius: 99px;
    }
    .timeline-bar-fill {
      position: absolute;
      left: 0; top: 0; bottom: 0;
      border-radius: 99px;
    }
    .timeline-today {
      position: absolute;
      width: 10px; height: 10px;
      border-radius: 50%;
      background: #0f172a;
      border: 2px solid white;
      box-shadow: 0 0 0 1px #0f172a;
      top: 50%; transform: translate(-50%, -50%);
    }
    .timeline-gate {
      position: absolute;
      width: 10px; height: 10px;
      border-radius: 50%;
      top: 50%; transform: translate(-50%, -50%);
      /* plain colored dot — no white ring, clearly distinct from today marker */
    }
    .timeline-dashed {
      height: 5px;
      border-radius: 99px;
      border: 1px dashed #cbd5e1;
      background: transparent;
    }
    .timeline-labels {
      display: flex;
      justify-content: space-between;
      font-size: 10px;
      color: #94a3b8;
    }
    .timeline-right-label { font-weight: 600; }
    .timeline-pending { font-size: 10px; color: #94a3b8; font-style: italic; }

    /* Next gate section */
    .next-gate-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: #94a3b8;
      text-transform: uppercase;
      margin-bottom: 3px;
    }
    .next-gate-row {
      display: flex;
      align-items: baseline;
      gap: 8px;
    }
    .next-gate-name  { font-size: 17px; font-weight: 800; color: #0f172a; }
    .next-gate-date  { font-size: 13px; font-weight: 700; }
    .next-gate-days  { font-size: 10px; font-weight: 600; margin-left: auto; }
    .criteria-wrap   { display: flex; flex-wrap: wrap; gap: 3px; margin-top: 5px; }
    .criteria-chip {
      font-size: 10px;
      padding: 2px 6px;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 3px;
      color: #475569;
    }
    .next-gate-empty { font-size: 12px; color: #94a3b8; font-style: italic; }

    /* Divider */
    .card-divider { border: none; border-top: 1px solid #f1f5f9; }

    /* Risks + Decisions */
    .section-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: #94a3b8;
      text-transform: uppercase;
      margin-bottom: 4px;
    }
    .risk-row, .decision-row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 6px;
      margin-bottom: 3px;
    }
    .risk-row:last-child, .decision-row:last-child { margin-bottom: 0; }
    .risk-icon     { color: #f59e0b; flex-shrink: 0; }
    .decision-icon { color: #6366f1; flex-shrink: 0; }
    .item-label  { font-size: 11px; color: #374151; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .item-meta   { font-size: 10px; color: #94a3b8; white-space: nowrap; flex-shrink: 0; }
    .risks-section, .decisions-section { display: flex; flex-direction: column; }

    /* ── Modal ───────────────────────────────────────── */
    #modal-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);
      z-index: 100;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    #modal-backdrop.open {
      display: flex;
    }

    #modal {
      background: white;
      border-radius: 12px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.15);
      max-width: min(85vw, 1100px);
      width: 100%;
      max-height: calc(100vh - 40px);
      overflow-y: auto;
      border-left-width: 4px;
      border-left-style: solid;
      border-top: 1px solid #e2e8f0;
      border-right: 1px solid #e2e8f0;
      border-bottom: 1px solid #e2e8f0;
      scrollbar-width: thin;
      scrollbar-color: #cbd5e1 transparent;
    }
    #modal::-webkit-scrollbar { width: 6px; }
    #modal::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 99px; }

    .modal-inner {
      padding: 20px 22px 24px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    /* Modal header */
    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .modal-header-left { display: flex; align-items: baseline; gap: 7px; }
    .modal-title { font-weight: 800; font-size: 17px; color: #0f172a; }
    .modal-subtitle { font-size: 11px; color: #94a3b8; }
    .modal-header-right { display: flex; align-items: center; gap: 6px; }
    #modal-close {
      color: #94a3b8;
      font-size: 18px;
      line-height: 1;
      cursor: pointer;
      padding: 2px 6px;
      border-radius: 4px;
      border: none;
      background: none;
      margin-left: 6px;
    }
    #modal-close:hover { color: #475569; background: #f1f5f9; }

    .modal-divider { border: none; border-top: 1px solid #e2e8f0; }

    /* Program schedule section */
    .modal-section-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: #94a3b8;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .schedule-track {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 14px;
    }
    .schedule-track:last-child { margin-bottom: 0; }

    .schedule-track-row {
      display: flex;
      align-items: flex-start;
      gap: 8px;
    }
    .schedule-track-label {
      font-size: 10px;
      color: #94a3b8;
      width: 20px;
      flex-shrink: 0;
      padding-top: 18px; /* align with milestone dots */
      font-weight: 600;
    }

    .schedule-milestones {
      flex: 1;
      display: flex;
      align-items: flex-start;
      position: relative;
    }

    /* The connecting line behind all dots */
    .schedule-milestones::before {
      content: '';
      position: absolute;
      top: 18px; /* center of the dot (dot is 10px, text ~16px above) */
      left: 5px;
      right: 5px;
      height: 1px;
      background: #e2e8f0;
      z-index: 0;
    }

    .schedule-milestone {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      position: relative;
      z-index: 1;
    }

    .sched-name {
      font-size: 10px;
      color: #94a3b8;
      margin-bottom: 4px;
      text-align: center;
      white-space: nowrap;
    }
    .sched-name.current { color: #0f172a; font-weight: 700; }

    .sched-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
      position: relative;
    }
    /* complete: filled with status or muted color */
    .sched-dot.complete {
      border: none;
    }
    /* current: filled + pulse ring */
    .sched-dot.current {
      border: 2px solid white;
      box-shadow: 0 0 0 2px currentColor;
    }
    /* upcoming: open circle */
    .sched-dot.upcoming {
      background: white !important;
      border: 1.5px solid #cbd5e1;
    }

    .sched-date {
      font-size: 10px;
      color: #94a3b8;
      margin-top: 4px;
      text-align: center;
      white-space: nowrap;
    }

    /* today marker on schedule — vertical dashed line at current phase position */
    .sched-today-marker {
      position: absolute;
      top: 4px;
      bottom: 4px;
      width: 1px;
      transform: translateX(-50%);
      pointer-events: none;
      z-index: 2;
      background-image: repeating-linear-gradient(
        to bottom,
        #6366f1 0,
        #6366f1 4px,
        transparent 4px,
        transparent 8px
      );
    }

    /* Modal next gate — full criteria */
    .modal-criteria-wrap { display: flex; flex-wrap: wrap; gap: 3px; margin-top: 6px; }

    /* Modal decisions */
    .modal-decision-row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 6px;
      margin-bottom: 6px;
    }
    .modal-decision-row:last-child { margin-bottom: 0; }
    .modal-decision-left { display: flex; align-items: baseline; gap: 5px; flex: 1; min-width: 0; }
    .modal-decision-label { font-size: 13px; font-weight: 700; color: #0f172a; }
    .modal-decision-meta { font-size: 11px; color: #94a3b8; white-space: nowrap; flex-shrink: 0; }
    .modal-decision-options {
      margin-top: 4px;
      margin-left: 16px;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .modal-decision-option {
      font-size: 11px;
      color: #475569;
      font-style: italic;
    }
    .modal-decision-option::before {
      content: '·';
      margin-right: 5px;
      font-style: normal;
      color: #94a3b8;
    }
    .modal-decision-block { margin-bottom: 10px; }
    .modal-decision-block:last-child { margin-bottom: 0; }

    /* Modal risks */
    .modal-risk-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 6px;
      margin-bottom: 8px;
    }
    .modal-risk-row:last-child { margin-bottom: 0; }
    .modal-risk-left { display: flex; align-items: center; gap: 6px; flex: 1; min-width: 0; }
    .modal-risk-label { font-size: 13px; font-weight: 700; color: #374151; }
    .modal-risk-meta { font-size: 11px; color: #94a3b8; white-space: nowrap; flex-shrink: 0; }
    .risk-rag {
      width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; display: inline-block;
    }
    .risk-rag-red   { background: #dc2626; }
    .risk-rag-amber { background: #d97706; }
    .risk-rag-green { background: #059669; }
    .modal-risk-desc {
      font-size: 11px;
      color: #64748b;
      margin-top: 2px;
      margin-left: 16px;
    }
    .modal-risk-block { margin-bottom: 10px; }
    .modal-risk-block:last-child { margin-bottom: 0; }
  </style>
</head>
<body>

<!-- ── Top Nav Bar ─────────────────────────────────────────────── -->
<nav id="nav">
