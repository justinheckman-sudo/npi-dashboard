</div>

<!-- ── Card Grid ─────────────────────────────────────────────── -->
<div id="grid-wrap">
  <div id="card-grid">
    <!-- injected by JS -->
  </div>
</div>

<!-- ── Modal ─────────────────────────────────────────────────── -->
<div id="modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="modal-title-text">
  <div id="modal">
    <div class="modal-inner" id="modal-content">
      <!-- injected by JS -->
    </div>
  </div>
</div>

